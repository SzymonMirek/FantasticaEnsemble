---
import { Image } from "astro:assets";
import albumyHeadlineImg from "../assets/albumyHeadline.png";
import plytyEclipse from "../assets/plytyEclipseLol.png";
import { ViewTransitions } from "astro:transitions";
import Wydarzenia from "../components/Wydarzenia.astro";
---

<head>
  <ViewTransitions />
</head>

<div class="calendar-container">
  <section class="calendar-headline">
    <div class="calendar-headline-text">
      <h1>Kalendarz</h1>

      <div class="toggle-wrapper">
        <input id="switch" type="checkbox" checked />
        <label for="switch">
          <div class="toggle-pill"></div>
          <div class="names">
            <p class="light">Przeszłe</p>
            <p class="dark">Nadchodzące</p>
          </div>
        </label>
      </div>
    </div>
  </section>

  <section class="calendar-section">
    <div id="events-upcoming" class="tab-content">
      <Wydarzenia type="upcoming" />
    </div>

    <div id="events-past" class="tab-content">
      <Wydarzenia type="past" />
    </div>
  </section>
</div>

<style>
  .calendar-container {
    display: grid;
    grid-template-columns: 100vw;
    /* Uproszczone wiersze tylko dla headline */
    grid-template-rows: auto;
    font-weight: 400;
    font-family: "Gilda Display";
    background: linear-gradient(180deg, #fff 0%, #ece4f0 100%);
  }

  /* Calendar head section*/

  /* Projekty Headline */
  .calendar-headline {
    width: 100vw;
    display: grid;
    /* grid-template-rows: 680px;  */
    /* grid-template-rows: 550px; */
    grid-template-rows: 580px;
    /* background: linear-gradient(180deg, #FFF 0%, #ECE4F0 100%); */
    overflow: hidden;
  }

  .calendar-headline-img-container {
    position: relative;
    grid-column: 2/3;
    justify-self: center;
    align-self: center;
    display: flex;
  }

  .albumyHeadlineImg {
    height: 29vw;
    width: auto;
    z-index: 1;
  }

  .albumyEclipseHeadline {
    position: absolute;
    top: -24vw;
    left: -24vw;
    z-index: 0;
  }

  .calendar-headline-text {
    grid-column: 1/2;
    align-self: center;
    font-family: "Gilda Display";
    text-align: center;
    font-size: 23px;
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-top: 130px;
  }

  .calendar-headline-text h1 {
    background: linear-gradient(180deg, #8e13f3 0%, #2599f8 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    /* font-size: calc(80px + 5.5vw); */
    /* font-size: min(17.4vw,calc(80px + 5.5vw)); */
    font-size: min(18.5vw, calc(80px + 5.5vw));
    padding-right: 1.3vw;
    font-weight: 400;
    margin: 0;
  }

  .calendar-headline-text p {
    /* padding: 0 7%; */
  }

  /* Responsive */
  @media screen and (min-width: 1800px) {
    .albumyEclipseHeadline {
      left: -1vw;
    }
  }

  /* @media screen and (max-width: 600px) {
        .calendar-headline {
            grid-template-rows: 1fr;
            grid-template-columns: 100vw;
            padding-top: 11vw;
            height: auto;
        }
        .calendar-headline-text {
            grid-row: 1/2;
            grid-column: 1/2;
        }
        .calendar-headline-img-container {
            grid-row: 2/3;
            grid-column: 1/2;
            margin-bottom: 10vw;
        }
        .albumyHeadlineImg {
            height: 59vw;
            width: auto;
        }
    } */

  #switch {
    display: none;
  }

  label {
    display: block;
    width: 16rem;
    height: 3.5rem;
    background-color: rgba(0, 0, 0, 0.1);
    border-radius: 100px;
    position: relative;
    cursor: pointer;
    margin: 2rem auto;
    margin-right: 1.15vw;
  }

  .toggle-wrapper {
    width: fit-content;
  }

  .toggle-pill {
    position: absolute;
    width: 46%;
    height: 3.5rem;
    background-color: #fff;
    border-radius: 100px;
    box-shadow: 0 2px 15px rgba(0, 0, 0, 0.15);
    transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    z-index: 1;
  }

  .names {
    font-size: 77%;
    /* font-weight: bolder; */
    color: black;
    width: -webkit-fill-available;
    margin-left: 2%;
    height: 100%;
    position: absolute;
    display: flex;
    justify-content: space-between;
    align-items: center;
    user-select: none;
    z-index: 2;
    justify-content: space-around;
    gap: -0.3vw;
  }

  .light,
  .dark {
    margin: 0;
    pointer-events: none;
  }

  #switch:checked + label .toggle-pill {
    transform: translateX(71.5%);
    width: 58.5%;
  }

  .dark {
    opacity: 0.5;
    /* padding-right: 6px; */
  }

  #switch:checked + label .dark {
    opacity: 1;
  }

  #switch:checked + label .light {
    opacity: 0.5;
  }

  /* Calendar section*/

  .calendar-section {
    padding-bottom: 18vh;
    /* padding-inline: calc(15vw - 100px); */
    padding-inline: max(5.5vw, calc(15vw - 100px));
    display: grid;
  }

  /* --- Style dla animacji zakładek --- */
  .tab-content {
    display: none; /* Domyślnie ukrywamy oba kontenery */
  }

  /* Klasa dodawana przez JS do aktywnego kontenera */
  .tab-content.active {
    display: grid;
    animation: fadeIn 0.5s ease-out forwards;
  }

  /* Definicja animacji: płynne pojawienie się i delikatny ruch do góry */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(-15px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @media screen and (max-width: 750px) {
    label {
      -webkit-tap-highlight-color: transparent;
      width: 15rem;
      height: 3.3rem;
      border-radius: 80px;
    }
    .toggle-wrapper {
    }
    .toggle-pill {
      height: 3.3rem;
    }
    .names {
      font-size: 70%;
    }
    .names > p {
      margin-top: 1px;
    }
    #switch {
      transform: translateX(76.3%);
      width: 56.5%;
    }
  }
  @media screen and (max-width: 660px) {
    .calendar-headline {
      /* grid-template-rows: calc(27.4vw + 400px); */
      grid-template-rows: calc(36.4vw + 410px);
    }
    .calendar-headline-text {
      margin-top: 120px;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    window.scrollTo(0, 0);

    const switchInput = document.getElementById("switch") as HTMLInputElement;
    const upcomingContainer = document.getElementById("events-upcoming");
    const pastContainer = document.getElementById("events-past");

    if (switchInput && upcomingContainer && pastContainer) {
      const updateView = () => {
        if (switchInput.checked) {
          // Switch zaznaczony -> pokazujemy Nadchodzące
          upcomingContainer.classList.add("active");
          pastContainer.classList.remove("active");
        } else {
          // Switch odznaczony -> pokazujemy Przeszłe
          upcomingContainer.classList.remove("active");
          pastContainer.classList.add("active");
        }
      };

      // Inicjalizacja stanu przy załadowaniu strony
      updateView();

      // Nasłuchiwanie na kliknięcia
      switchInput.addEventListener("change", updateView);
    }
  });
</script>
