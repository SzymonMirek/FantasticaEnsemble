---
import { Image } from "astro:assets";
import Strzlk from "../assets/strzlk4hover.png";

interface Props {
  event: {
    data: {
      dataWydarzenia: {
        dzien: string;
        mR: string;
      };
      nazwaWydarzenia: string;
      repertuar: string;
      miejsceWydarzenia: string;
      czasWydarzenia: string;
      linkWydarzenia?: string;
    };
    slug: string;
  };
}

const { event } = Astro.props;
const [month, year] = event.data.dataWydarzenia.mR.split(" ");
---

{
  event.data.linkWydarzenia ? (
    <div
      class="wydarzenie ma-link"
      id="wydarzenie-klik"
      onclick={`window.location.href='${event.data.linkWydarzenia}'`}
      style="cursor: pointer; position: relative;"
    >
      <div class="loader">
        <img src={Strzlk.src} alt="" />
      </div>
      <div class="data-wydarzenia">
        <p class="data-wydarzenia-dzien">{event.data.dataWydarzenia.dzien}</p>
        <p class="data-wydarzenia-m-r">
          {month.toLowerCase()}
          <br />
          {year}
        </p>
      </div>
      <a class="nazwaWydarzenia">{event.data.nazwaWydarzenia}</a>
      <a class="repertuar desktop-event-data">{event.data.repertuar}</a>
      <a class="miejsce-wydarzenia desktop-event-data">{event.data.miejsceWydarzenia}</a>
      <a class="czas-wydarzenia desktop-event-data">{event.data.czasWydarzenia}</a>
      <div class="mobile-event-data">
        <a class="repertuar">{event.data.repertuar}</a>
        <span>
          <a class="miejsce-wydarzenia">{event.data.miejsceWydarzenia} | </a>
          <a class="czas-wydarzenia">{event.data.czasWydarzenia}</a>
        </span>
      </div>
    </div>
  ) : (
    <div class="wydarzenie">
      <div class="data-wydarzenia">
        <p class="data-wydarzenia-dzien">{event.data.dataWydarzenia.dzien}</p>
        <p class="data-wydarzenia-m-r">
          {month.toLowerCase()}
          <br />
          {year}
        </p>
      </div>
      <span class="nazwaWydarzenia">{event.data.nazwaWydarzenia}</span>
      <span class="repertuar desktop-event-data">{event.data.repertuar}</span>
      <span class="miejsce-wydarzenia desktop-event-data">{event.data.miejsceWydarzenia}</span>
      <span class="czas-wydarzenia desktop-event-data">{event.data.czasWydarzenia}</span>
      <div class="mobile-event-data">
        <a class="repertuar">{event.data.repertuar}</a>
        <span>
          <a class="miejsce-wydarzenia">{event.data.miejsceWydarzenia} | </a>
          <a class="czas-wydarzenia">{event.data.czasWydarzenia}</a>
        </span>
      </div>
    </div>
  )
}

<style>
  .wydarzenie {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    font-family: "Gilda Display";
    align-items: center;
    width: 96%;
    height: 60px;
    border-top: 1px solid #e4277640;
    border-bottom: 1px solid #e4277640;
    padding: 0.3% 1% 0.3% 7px;
    margin-bottom: 23px;
    transition:
      background 0.3s,
      color 0.3s;
  }

  #wydarzenie-klik:hover {
    background: rgba(250, 250, 250, 0.7);
    /* backdrop-filter: blur(50px);  */
    cursor: pointer;
  }
  /* .wydarzenie:hover {
        background: rgba(250, 250, 250, 0.7); 
        backdrop-filter: blur(50px); 

    } */

  .data-wydarzenia {
    color: #353535;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0 7%;
  }
  .data-wydarzenia-dzien {
    height: 100%;
    padding-bottom: 12px;
    font-family: Elsie;
    font-size: 39px;
    font-weight: 900;
  }

  .data-wydarzenia-m-r {
    height: 100%;
    text-align: justify;
    font-family: "Gilda Display";
    font-size: 14px;
    font-weight: 400;
  }
  .nazwaWydarzenia {
    flex-basis: 220px;
    padding-left: 60px;
  }
  #lastella {
    margin-left: 22px;
  }
  .repertuar {
    flex-basis: 200px;
    padding-left: 33px;
  }
  .miejsce-wydarzenia {
    flex-basis: 120px;
  }
  .czas-wydarzenia {
    color: #a71250;
    flex-basis: 80px;
    text-align: right;
  }

  .loader {
    position: absolute;
    padding-bottom: 45px;
    right: 0.1vw;
    display: flex;
    justify-content: center;
    align-items: center;
    color: white;
  }
  .loader img {
    width: 10px;
    height: 10px;
  }

  @media screen and (max-width: 1150px) {
    .wydarzenia-cmpnt {
      max-width: 805px;
      width: auto;
      height: -webkit-fit-content;
    }
  }

  @media screen and (max-width: 1200px) {
    .wydarzenie a {
      font-size: 14px;
    }
    /* .repertuar {
                flex-basis: 180px;
            } */
  }
  @media screen and (min-width: 660px) {
    .mobile-event-data {
      display: none;
    }
  }
  @media screen and (min-width: 660px) and (max-width: 750px) {
    .repertuar {
      padding-right: 16px;
    }
  }
  @media screen and (max-width: 660px) {
    .desktop-event-data {
      display: none;
    }
    .mobile-event-data {
      display: grid;
      grid-row: 2/3;
      grid-column: 2/3;
    }
    .wydarzenie {
      display: grid;
      /* grid-template-columns: 0.85fr 1.2fr 0.9fr; */
      /* grid-template-columns: 0.85fr 1.8fr 0.5fr; */

      grid-template-columns: 0.91fr 1.8fr 0.5fr;
      /* grid-template-columns: 1.01fr 1.8fr 0.5fr; */

      /* grid-template-rows: auto 60px; */
      grid-template-rows: 47px 60px;
      /* height: 112px; */
      height: auto;
      width: 97%;
      padding-bottom: 0.9vh;
      align-items: self-start;
      padding-top: 8px;
    }
    .data-wydarzenia {
      grid-column: 1 / 2;
      grid-row: 1 / 3;
      align-items: start;
      flex-direction: column;

      /* padding-left: 2.5vw; */
    }
    .data-wydarzenia-dzien {
      margin: 0;
      margin-top: 4px;
      padding-bottom: 3px;
    }
    .data-wydarzenia-m-r {
      margin: 0;
      margin-top: 5px;
      padding-bottom: 0px;
      padding-left: 3px;
    }
    .nazwaWydarzenia {
      grid-column: 2/3;
      grid-row: 1/2;
      padding-top: 14px;
      padding-left: 0;
      font-family: "Elsie";
      font-size: 17px;
      padding-bottom: 13px;
    }
    .czas-wydarzenia {
      /* grid-column: 3/4;
      grid-row: 1/2; */
      padding-top: 13px;
    }
    .repertuar {
      /* grid-column: 2/3;
      grid-row: 2/3; */
      align-self: end;
      padding-bottom: 5px;
      padding-left: 0;
      color: #5c5c5c;
    }
    .miejsce-wydarzenia {
      /* grid-column: 3/4;
      grid-row: 2/3; */
      text-align: right;
      align-self: end;
      padding-bottom: 10px;
    }
    #lastella {
      margin-left: 0;
    }
    .loader {
      left: 1.4vw;
      padding-top: 94px;
    }

    .ma-link .miejsce-wydarzenia {
      padding-bottom: 10px;
      margin-right: 28px;
    }
    .ma-link .loader {
      right: -82.6vw;
      padding-top: 70px;
    }
  }
  @media screen and (max-width: 580px) {
    .ma-link .miejsce-wydarzenia {
      padding-bottom: 27px;
      margin-right: 0;
    }
    .ma-link .loader {
      right: -82.6vw;
      padding-top: 26px;
    }
  }
</style>
