];
---

<div class="wydarzenia-cmpnt">
  {events.map((event) => <EventCard event={event} />)}
</div>

<style>
  .wydarzenia-cmpnt {
    display: flex;
    flex-direction: column;
    gap: 2% 2%;
    width: 100%;
    margin-top: 8px;
  }
</style>
