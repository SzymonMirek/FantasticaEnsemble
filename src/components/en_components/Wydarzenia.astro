---
import { getCollection } from "astro:content";
import EventCard from "../../components/en_components/EventCard.astro";

// Definiujemy prop "type" dla wersji angielskiej
interface Props {
  type: "past" | "upcoming";
}
const { type = "upcoming" } = Astro.props;

// Pobieramy kolekcję "events" (angielską)
const allEvents = await getCollection("events");

// Helper function dostosowany do angielskich kluczy i miesięcy
function convertToDate(dateObj: any) {
  // Czyścimy string (obsługa <br> i spacji)
  const monthYear = dateObj.monthYear.replace("<br>", " ").trim().toLowerCase();
  const [monthAbbr, year] = monthYear.split(" ");

  const monthNames = [
    "jan",
    "feb",
    "mar",
    "apr",
    "may",
    "jun",
    "jul",
    "aug",
    "sep",
    "oct",
    "nov",
    "dec",
  ];

  const monthIndex = monthNames.indexOf(monthAbbr);

  // Ważne: używamy dateObj.day oraz przeliczonego monthIndex
  return new Date(parseInt(year), monthIndex, parseInt(dateObj.day));
}

// Obecna data do porównań
const now = new Date();
now.setHours(0, 0, 0, 0);

// Filtrowanie i sortowanie
const filteredEvents = allEvents
  .filter((event) => {
    const eventDate = convertToDate(event.data.eventDate);
    if (type === "past") return eventDate < now;
    return eventDate >= now;
  })
  .sort((a, b) => {
    const dateA = convertToDate(a.data.eventDate).getTime();
    const dateB = convertToDate(b.data.eventDate).getTime();

    // Upcoming: closest first | Past: newest first
    return type === "past" ? dateB - dateA : dateA - dateB;
  });
---

<div class="wydarzenia-cmpnt">
  {
    filteredEvents.length > 0 ? (
      filteredEvents.map((event) => <EventCard event={event} />)
    ) : (
      <p class="brak-wydarzen">No events to display.</p>
    )
  }
</div>

<style>
  .wydarzenia-cmpnt {
    display: flex;
    flex-direction: column;
    gap: 2% 2%;
    width: 70vw;
    margin-top: 8px;
    justify-self: center;
    height: -webkit-fit-content;
  }
  .brak-wydarzen {
    text-align: center;
    font-family: "Gilda Display";
    color: #555;
    margin-top: 2rem;
  }
  @media screen and (max-width: 1150px) {
    .wydarzenia-cmpnt {
      max-width: 805px;
      width: -webkit-fill-available;
    }
  }
</style>
